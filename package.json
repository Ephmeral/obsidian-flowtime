{
  "name": "obsidian-flowtime",
  "version": "0.1.0",
  "description": "Sync FlowTime daily logs into an Obsidian vault.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "tsc -p tsconfig.test.json && node --test test/*.test.mjs",
    "sync:vault": "npm run build && node scripts/sync-vault.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "flowtime",
    "time-tracking"
  ],
  "license": "0-BSD",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "esbuild": "0.25.5",
    "tslib": "2.4.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "obsidian": "latest"
  }
}
